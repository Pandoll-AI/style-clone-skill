 "example_bank": {
  "다": [
   "그 포우즈가 부동자세에까지 고도화할 때 감정은 딱 공급을 정지합네다.",
   "그 33번지라는 것이 구조가 흡사 유곽이라는 느낌이 없지 않다.",
   "한 번지에 18가구가 죽 어깨를 맞대고 늘어서서 창호가 똑같고 아궁이 모양이 똑같다."
  ],
  "ᆫ다": [
   "턱살 밑에다 철줄을 매고 얼룩진 이부자리를 널어 말린다는 핑계로 미닫이에 해가 드는 것을 막아 버린다.",
   "아침결에 책보 만한 해가 들었다가 오후에 손수건만 해지면서 나가 버린다.",
   "이렇게 볕드는 방이 아내 방이요, 볕 안드는 방이 내 방이요 하고 아내와 나 둘 중에 누가 정했는지 나는 기억하지 못한다."
  ],
  "명사종결": [
   "사람들은 모두 네 활개를 펴고 닭처럼 푸드덕거리는 것 같고 온갖 유리와 강철과 대리석과 지폐와 잉크가 부글부글 끓고 수선을 떨고 하는 것 같은 찰나!",
   "“속아도 꿈결 속여도 꿈결 굽이굽이 뜨내기 세상 그늘진 심정에 불질러 버려라 운운.”",
   "나는 드디어 쭈굴쭈굴하게 노쇠해 버렸던 차에 아침(이 온 것)을 보고 이키!"
  ],
  "오": [
   "'박제가 되어 버린 천재'를 아시오?",
   "니코틴이 내 횟배 앓는 뱃속으로 스미면 머릿속에 으레 백지가 준비되는 법이오.",
   "나는 또 여인과 생활을 설계하오."
  ],
  "는다": [
   "나는 그러나 그들의 아무와도 놀지 않는다.",
   "놀지 않을 뿐만 아니라 인사도 않는다.",
   "어느덧 손수건만해졌던 볕이 나갔는데 아내는 외출에서 돌아오지 않는다."
  ],
  "ᆯ까": [
   "그것은 그저 예의에 지나지 않는 것일까?",
   "그렇지 않으면 혹 무슨 댓가일까?",
   "열 한 시가 좀 지났구나, 여기도 결코 내 안주의 곳은 아니구나, 어디 가서 자정을 넘길까?"
  ],
  "지": [
   "“엊저녁에 왔던 수염 난 양반, 내가 바루 아들이지.",
   "“열여섯 살에 머리 얹어서 열일곱 살에 낳았지.”",
   "“네놈 하나 보구져서 서울 왔지"
  ],
  "나": [
   "그러나 왜 그들 내객은 돈을 놓고 가나?",
   "왜 내 아내는 그 돈을 받아야 되나?",
   "그러나 그런 것을 상고하여 무엇하나?"
  ],
  "자": [
   "나는 한마디 가련한 어휘를 첨가할 성의를 보이자.",
   "그냥 어디 이대로 써〔用〕보기로 하자.",
   "그리 칠칠치는 못하나마 이만큼 해가지고 이 꼴 저 꼴 구지레한 흠집을 살짝 도회(韜晦)하기로 하자."
  ],
  "라": [
   "나는 이런 양식 아래 금홍이와 이별했더니라.",
   "‘중병에 걸려 누웠으니 얼른 오라’고.",
   "맥은 탁 풀리고는 앞이 팽 돌다 아찔 하는 것이 이러다가 까무러치려나 보다고 극력(極力) 단장을 의지하여 버텨보노라니까 희(噫)라!"
  ],
  "느냐": [
   "넘어가는 내 지지한 종생, 이렇게도 실수가 허(許)해서야 물화적(物貨的) 전생애(全生涯)를 탕진해 가면서 사수하여온 산호편의 본의가 대체 어디 있느냐?",
   "현역(現役) 육군중좌(陸軍中佐)에게서 받은 추상열일의 훈육(訓育)을 왜 나는 이 경우에 버젓하게 내세우지를 못하느냐?",
   "나는 그럼 지고 그만 두느냐."
  ],
  "습니다": [
   "다섯 달 동안 저에게는 아무것도 없습니다.",
   "저의 최후까지 더럽히지 않은 것을 선생님께 드리겠습니다.",
   "저의 히멀건 살의 매력이 이렇게 다섯 달 동안이나 놀고 없는 것은 참 무엇이라고 말할 수 없이 아깝습니다."
  ]
 }
