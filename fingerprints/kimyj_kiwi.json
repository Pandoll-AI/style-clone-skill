 "example_bank": {
  "다": [
   "땅속 저 밑은 늘 음침하다.",
   "밤과 달라서 낮엔 되우 흐릿하였다.",
   "싸늘한 침묵, 쿠더브레한 흙내와 징그러운 냉기만이 그 속에 자욱하다."
  ],
  "ᆫ다": [
   "그러나 간간 우수수 하고 벽이 헐린다.",
   "흙 한줌을 집어 코밑에 바짝 들여대고 손가락으로 샅샅이 뒤져본다.",
   "땅에 무릎을 꿇고 궁뎅이를 번쩍 든 채 식식거린다."
  ],
  "명사종결": [
   "겉으로 황토 장벽으로 앞뒤좌우가 콕 막힌 좁직한 구뎅이.",
   "아직도 버력을 다 못 친 모양.",
   "이 자식이 일을 하나 시졸 하나."
  ],
  "어": [
   "남은 속이 바직바직 타는데 웬 뱃심이 이리도 좋아.",
   "“인내, 그리구 여기 가만히 섰어.”",
   "한 포에 댓 돈씩은 넉넉잡히대.”"
  ],
  "는다": [
   "영식이는 일손을 놓고 소맷자락을 끌어당기어 얼굴의 땀을 훑는다.",
   "그러나 그는 눈도 하나 깜짝하지 않는다.",
   "광부를 삼백여 명이나 부리는 노다지판인데 매일 소출되는 금이 칠십 냥을 넘는다."
  ],
  "지": [
   "“왜 이리 앉었수, 불 좀 지피지.”",
   "가지가지 나무에는 싱싱한 싹이 돋고, 새침히 옷깃을 핥고 드는 요놈이 꽃샘이겠지.",
   "이것은 필시 아키코에게 엇먹는 조롱이겠지."
  ],
  "야": [
   "“말라니까 왜 또 파는 게야.” 하고 영식이의 바지게 뒤를 지팡이로 콱 찌르더니,",
   "하기는 금만 잘 터져나오면 이까진 콩밭쯤이야.",
   "“구구루 땅이나 파먹지 이게 무슨 지랄들이야!”"
  ],
  "ᆫ가": [
   "그러나 며칠 뒤에는 다비신에다 옥당목을 떨치고 히짜를 뽑는 것이 아닌가.",
   "그 소중한 밭에다 구멍을 뚫고 이 지랄이니 그놈이 온전할 겐가.",
   "요렇게 암팡스레 패 주는 것이 아닌가."
  ],
  "어요": [
   "저 연애 편지 하나만 써주셔요.\"",
   "\"언니 머리같이 더 좀 디려 잘라 주어요.\"",
   "\"그래 너 주려구 과자 사왔어요.\""
  ],
  "냐": [
   "우선 삼십만 원만 해도 얼마냐.",
   "계집애가 나물을 캐러 가면 갔지 남 울타리 엮는 데 쌩이질을 하는 것은 다 뭐냐.",
   "게다가 눈에 독을 올리고 한참 나를 요렇게 쏘아보더니 나중에는 눈물까지 어리는 것이 아니냐."
  ],
  "니": [
   "남의 닭 알 못 낳으라구 그러니?\"",
   "\"요담부터 또 그래 봐라, 내 자꾸 못살게 굴 테니.\"",
   "\"닭 죽은 건 염려 마라, 내 안 이를 테니.\""
  ],
  "유": [
   "“아주머니, 이것 좀 먹게 해주시게유.”",
   "\"참, 우리 같은 농군에 대면 호강살이유!\""
  ]
 }
