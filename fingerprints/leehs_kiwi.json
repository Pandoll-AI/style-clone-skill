 "example_bank": {
  "다": [
   "들은 온통 초록 전에 덮여 벌써 한 조각의 흙빛도 찾아볼 수 없다.",
   "초록은 흙빛보다 찬란하고 눈빛보다 복잡하다.",
   "눈이 보얗게 깔렸을 때에는 흰빛과 능금나무의 자줏빛과 그림자의 옥색빛밖에는 없어 단순하기 옷 벗은 여인의 나체와 같은 것이―---봄은 옷 입고 치장한 여인이다."
  ],
  "ᆫ다": [
   "풀 위에 누워 있으면 은근한 음악의 율동에 끌려 마음이 너볏너볏 나부낀다.",
   "눈을 돌리면 눈물이 푹 쏟아진다.",
   "벌판이 새파랗게 물들어 눈앞에 아물아물한다."
  ],
  "ᆯ까": [
   "그것을 빗물에 풀어 시절이 되면 땅 위로 솟쳐 보내는 것일까.",
   "그러나 한 포기의 풀을 뽑아 볼 때 잎새만이 푸를 뿐이지 뿌리와 흙에는 아무 물들인 자취도 없음은 웬일일까.",
   "부피 있는 대궁은 나팔 소리요, 가는 가지는 거문고의 음률이라고도 할까."
  ],
  "명사종결": [
   "꽃다지, 길경이, 나생이, 딸장이, 먼둘네, 솔구장이, 쇠민장이, 길오장이, 달래, 무릇, 시금초, 씀바구, 돌나물, 비름, 능쟁이.",
   "얀들얀들 나부끼는 초목의 양자는 부드럽게 솟는 음악.",
   "오랑캐꽃, 고들뱅이, 노고초, 새고사리, 가처무릇, 대게, 맛탈, 차치광이."
  ],
  "어요": [
   "우스운 이야기나, 그러기 때문에 지금까지 아버지 얼굴도 본 적 없고 있는 고장도 모르고 지내와요.”",
   "“갑남이가 안 먹으면 먹구 싶지 않아요.”",
   "무엇보다도 먼저 몸을 푹 휴양해야겠어요.\""
  ],
  "지": [
   "\"자네 걸은 길대로 되어 나가는 것이 뻔하지.",
   "연소패들을 적수로 하구야 대거리가 돼야 말이지.”",
   "그 꼴에 우리들과 한몫 보자는 셈이지."
  ],
  "예요": [
   "“부끄러워서 말하지 않으랴 했으나 정말예요.",
   "\"선생이 나와서 뵈는 첫 분예요.",
   "\"적어도 오늘의 문제는 아닐 거예요.\""
  ],
  "오": [
   "죄니 양심이니 하는 것이야말로 도리어 일종의 장식물이 아니오?",
   "오는 대로 받아들이는 것이 더 인간적인가 하오.",
   "\"의견을 버리고 내 설계대로만 좇으시오."
  ],
  "을까": [
   "흙빛에서 초록으로―---이 기막힌 신비에 다시 한번 놀라 볼 필요가 없을까.",
   "땅은 어디서 어느 때 그렇게 많은 물감을 먹었기에 봄이 되면 한꺼번에 그것을 이렇게 지천으로 뱉어 놓을까.",
   "이 우주의 비밀의 약품―---그것은 결국 알 바 없을까."
  ],
  "어": [
   "봉평 장에서 한번이나 흐붓하게 사본 일 있을까해.",
   "“달밤이었으나 어떻게 해서 그렇게 됐는지 지금 생각해두 도무지 알 수 없어.”",
   "그렇게 신통한 일이란 쉽지 않어."
  ],
  "지요": [
   "\"하긴 샴페인도 백포도주 같기는 하지요.\"",
   "\"이것이야 칠면조 아닌 틀림없는 닭고기겠지요.\"",
   "월계나무 잎새 대신에 호박 잎새나 잔뜩 뜯어 가시지요."
  ],
  "네": [
   "자네가 버드나무숲에서 만났다면 나는 풀밭에서 만났네.\"",
   "내일 대화 장에서가 한몫 벌어야겠네.”",
   "“장 선 꼭 이런 날 밤이었네."
  ]
 }
